NEXT_PUBLIC_APP_NAME=Update Center
NEXT_PUBLIC_APP_DESCRIPTION=Software update management dashboard
# Coolify: set all NEXT_PUBLIC_* vars as BUILD-TIME env vars (Next.js bakes them in at build).
# Local dev:
# NEXT_PUBLIC_API_URL=http://localhost:3000/v1
# NEXT_PUBLIC_WS_URL=http://localhost:3000
# NEXT_PUBLIC_ENROLL_BASE_URL=http://localhost:3001/enroll
# NEXT_PUBLIC_CONNECT_BASE_URL=http://localhost:3001/connect
# NEXT_PUBLIC_AGENT_DOWNLOAD_URL=http://localhost:3000/v1/agent/download
# Optional TURN via Cloudflare — configured on remotehick backend, not here.
# Clients call GET /v1/webrtc/ice-servers with admin JWT or device token.
# See remotehick .env: CLOUDFLARE_TURN_KEY_ID + CLOUDFLARE_TURN_API_TOKEN
NEXT_PUBLIC_API_URL=https://dev.digitalcoresystem.com/v1
NEXT_PUBLIC_WS_URL=https://dev.digitalcoresystem.com
NEXT_PUBLIC_ENROLL_BASE_URL=https://front.digitalcoresystem.com/enroll
NEXT_PUBLIC_CONNECT_BASE_URL=https://front.digitalcoresystem.com/connect
NEXT_PUBLIC_AGENT_DOWNLOAD_URL=https://dev.digitalcoresystem.com/v1/agent/download
