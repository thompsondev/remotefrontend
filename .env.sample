NEXT_PUBLIC_APP_NAME=
NEXT_PUBLIC_APP_DESCRIPTION=
NEXT_PUBLIC_CONTACT_URL=
NEXT_PUBLIC_PRIVACY_URL=
NEXT_PUBLIC_HOMEPAGE=
NEXT_PUBLIC_APP_THEME=#8ffe09
# Home splash: minimum time (ms) the logo shows before session redirect logic runs (default 4000).
NEXT_PUBLIC_HOME_SPLASH_MS=4000
# Nest Better Auth: API origin only (no path). Prefer BETTER_AUTH_URL; falls back to AUTH_URL.
NEXT_PUBLIC_BETTER_AUTH_URL=
NEXT_PUBLIC_AUTH_URL=
NEXT_PUBLIC_AUTH_BASE_PATH=/v1/auth
# Cookie session read (Nest): default GET /v1/user/session
# NEXT_PUBLIC_USER_SESSION_PATH=/v1/user/session
# Cloudflare Turnstile site key (public). No quotes. In Turnstile → widget → hostnames, add every
# origin you use (e.g. localhost:3000 and 127.0.0.1:3000 are different hosts).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=